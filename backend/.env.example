# Database
DATABASE_URL=postgresql://user:password@localhost:5432/evidentia_dev

# Auth
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
# Whoever registers with this email becomes the system admin (optional)
ADMIN_EMAIL=

# NCBI / PubMed
# Get key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=your-email@example.com

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5

# Crossref (only email required, no key)
CROSSREF_EMAIL=your-email@example.com

# Unpaywall (only email required)
UNPAYWALL_EMAIL=your-email@example.com

# CORE (optional) — free OA full-text aggregator. Key at https://core.ac.uk/services/api
CORE_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe recurring Price IDs (one product, two prices — monthly & annual).
# Checkout Sessions are created server-side; the 7-day trial is set in code.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Marketing funnel (n8n -> MailerLite)
# Backend POSTs funnel events (signup, checkout_started, trial_*, etc.) here.
# Leave empty to disable the funnel entirely (graceful no-op).
N8N_WEBHOOK_URL=
# Optional shared secret; sent as the x-evidentia-secret header so the n8n
# webhook can reject forged requests. Must match the value checked in n8n.
N8N_WEBHOOK_SECRET=

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
